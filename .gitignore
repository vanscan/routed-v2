# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code — local agent tooling, not project dependencies
**/.claude-user
.claude/settings.local.json
/package.json
/package-lock.json

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Token / credential payloads (NOT .env — those are tracked, see below)
*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# EAS local build artifacts (large, regenerated by `eas build`)
builds/

# Tile cache / prebuilt SQLite databases — large binaries that must NOT be
# in version control (they bloat pushes and trip GitHub's file-size limits).
# EXCEPTION: tiles/buildings.db is a prebuilt dataset the Dockerfile COPYs at
# build time, so it MUST stay tracked. Only the runtime tile CACHE
# (qld_cache.db + its WAL/SHM sidecars, regenerated on the fly) is ignored.
tiles/*.db
!tiles/buildings.db
tiles/*.db-shm
tiles/*.db-wal

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Mobile development
android-sdk/

model.patch
queensland.osm.pbf
queensland.osrm*
osrm-backend/

# ─────────────────────────────────────────────────────────────────────
# .env files must NOT be committed. They contain live production secrets
# (database credentials, JWT signing secrets, API keys). Secrets must be
# injected at deploy time via the hosting platform's secret/env-var UI
# (Railway Variables, Fly.io secrets, Replit Secrets, etc.).
#
# Use backend/.env.example as the canonical list of required variables.
# Copy it to backend/.env locally and fill in real values; never commit
# that filled-in file.
# ─────────────────────────────────────────────────────────────────────
.env
.env.*
*.env
!*.env.example
# Exception: frontend production config holds ONLY public EXPO_PUBLIC_* client
# values (Supabase URL/anon key, Google client IDs, public backend URL). These
# are compiled into the browser bundle and are NOT secret. Required by the
# Replit static web deploy so `expo export` targets the production backend.
!frontend/.env.production
credentials.json
*.pem
*.key
.credentials
