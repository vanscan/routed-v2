modules = ["nodejs-20", "bash", "web", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["glibcLocales"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && uvicorn server:app --host localhost --port 8000"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx expo start --web --port 5000 --host localhost"
waitForPort = 5000

[[ports]]
localPort = 5000

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8000

[deployment]
deploymentTarget = "static"
run = ["bash", "-c", "cd backend && uvicorn server:app --host 0.0.0.0 --port 8000 & cd frontend && npx expo start --web --port 5000 --host localhost --no-dev"]
build = ["bash", "-c", "cd frontend && npm install --legacy-peer-deps && npx expo export -p web"]
publicDir = "frontend/dist"

[objectStorage]
defaultBucketID = "replit-objstore-01753d05-d523-4695-95dc-656e76546043"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
