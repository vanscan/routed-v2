# ---------------------------------------------------------------------------
# Routed — Backend environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database (MongoDB) ----------------------------------------------------
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<AppName>
DB_NAME=routed
# Grace period (seconds) the API waits for the DB to become ready on boot.
DB_READY_GRACE_SECONDS=300

# --- Maps / LLM ------------------------------------------------------------
MAPBOX_TOKEN=pk.eyJ1...
EMERGENT_LLM_KEY=sk-emergent-...
GENEROUTE_API_KEY=...

# --- AWS -------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-southeast-2

# --- OSRM routing ----------------------------------------------------------
OSRM_URL=http://localhost:5000
OSRM_PUBLIC_URL=https://router.project-osrm.org
OSRM_URL_PROD=https://<your-osrm-host>.fly.dev
# Base URL used by the zipper route (defaults to the in-cluster osrm service).
OSRM_BASE_URL=http://osrm:5000

# --- Runtime flags ---------------------------------------------------------
DEV_MODE=false
ENABLE_TIMEFOLD=false
# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=https://api.getrouted.xyz

# --- Tile cache ------------------------------------------------------------
TILE_CACHE_ADMIN_TOKEN=<random-hex-string>
# Path to the SQLite tile cache database.
TILE_CACHE_DB=/app/tiles/qld_cache.db

# --- Stripe billing --------------------------------------------------------
STRIPE_API_KEY=sk_live_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ADMIN_USER_IDS=
STRIPE_CHECKOUT_SUCCESS_URL=https://<your-api-domain>/billing/success
STRIPE_CHECKOUT_CANCEL_URL=https://<your-api-domain>/billing/cancel

# --- Access control --------------------------------------------------------
# Comma-separated email allowlist. Leave empty to allow all.
ALLOWED_USERS_CSV=
# Set to "true" to disable new signups.
SIGNUPS_DISABLED=false

# Reviewer allowlist for Play Store review accounts.
# Leave REVIEWER_PASSCODE empty/unset to disable the endpoint entirely.
# Use a strong randomly-generated passcode (e.g. openssl rand -base64 32).
REVIEWER_EMAILS=
REVIEWER_PASSCODE=

# Comma-separated user IDs that have Telepathy ML access
TELEPATHY_USER_IDS=

# --- Supabase --------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
# The JWT secret is found in Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# --- Google OAuth (verifying Google ID tokens) -----------------------------
GOOGLE_WEB_CLIENT_ID=<project-id>.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=<project-id>.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=<project-id>.apps.googleusercontent.com
