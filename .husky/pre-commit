#!/usr/bin/env sh
# Pre-commit hook: refuse any commit that introduces real secret values into
# backend/.env. Secrets must be injected via platform environment variables
# at deploy time, not committed to the repository.
#
# Bypass for emergency commits (use sparingly):
#   git commit --no-verify

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec "${REPO_ROOT}/scripts/pre-deploy-audit.sh"
