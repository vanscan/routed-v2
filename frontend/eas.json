{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://api.getrouted.xyz",
        "EXPO_PUBLIC_USE_NATIVE_MAP": "true"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://api.getrouted.xyz"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://api.getrouted.xyz",
        "EXPO_PUBLIC_USE_NATIVE_MAP": "true"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-apk": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://api.getrouted.xyz",
        "EXPO_PUBLIC_USE_NATIVE_MAP": "true"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "Production": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    },
    "production": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    },
    "playstore": {
      "android": {
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    },
    "internal": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed",
        "changesNotSentForReview": false
      }
    },
    "alpha": {
      "android": {
        "track": "alpha",
        "releaseStatus": "completed",
        "changesNotSentForReview": false
      }
    },
    "beta": {
      "android": {
        "track": "beta",
        "releaseStatus": "completed",
        "changesNotSentForReview": false
      }
    }
  }
}
