{
  "name": "frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "check:props": "node ./scripts/check-props.js",
    "test:unit": "node ./scripts/test-resume-navigation.js",
    "clean:garbage": "node ./scripts/clean-garbage.js",
    "prebuild:check": "CI=true expo prebuild --no-install --platform android --clean && rm -rf android",
    "deploy:preflight": "bash /app/ensure_eas_deps.sh && bash /app/scripts/gitignore-autoheal.sh && bash /app/scripts/pre-deploy-audit.sh && node ./scripts/clean-garbage.js && node ./scripts/check-props.js && node ./scripts/test-resume-navigation.js && node ./scripts/check-expo-deps.js && node ./scripts/check-backend-url.js && echo '[preflight] OK — safe to deploy'",
    "predeploy": "bash /app/scripts/predeploy.sh",
    "predeploy:fast": "bash /app/scripts/predeploy.sh --skip-tests",
    "eas:build:android": "yarn deploy:preflight && eas build --platform android --profile preview",
    "update:prod": "bash /app/scripts/gitignore-autoheal.sh && bash /app/scripts/pre-deploy-audit.sh && node ./scripts/eas-update-guarded.js --branch production --environment production --platform android",
    "postinstall": "sh ./scripts/fix-hermesc-arm64.sh",
    "prepare": "cd .. && git config core.hooksPath .husky 2>/dev/null || true"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@expo/metro-runtime": "^6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.1.1",
    "@maplibre/maplibre-react-native": "11.3.4",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.17.2",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/native-stack": "^7.17.2",
    "@supabase/supabase-js": "^2.108.0",
    "@types/react": "~19.2.17",
    "axios": "^1.17.0",
    "date-fns": "^4.4.0",
    "expo": "~54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~56.0.7",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "^14.0.8",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~56.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "~8.0.12",
    "expo-location": "^56.0.16",
    "expo-navigation-bar": "~5.0.10",
    "expo-router": "~6.0.24",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~56.0.18",
    "expo-web-browser": "~15.0.11",
    "maplibre-gl": "^5.24.0",
    "merge-options": "^3.0.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-map-gl": "^8.1.1",
    "react-native": "0.85.3",
    "react-native-dotenv": "^3.4.11",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~3.0.0",
    "react-native-reanimated": "~4.4.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.9.1",
    "typescript": "~5.9.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/jest": "30.0.0",
    "babel-preset-expo": "~56.0.14",
    "husky": "^9.1.7"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@react-native-async-storage/async-storage"
      ]
    }
  },
  "resolutions": {
    "@react-navigation/native": "7.3.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
