# ---------------------------------------------------------------------------
# Routed — Frontend (Expo) environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# All client-exposed vars MUST be prefixed with EXPO_PUBLIC_.
# ---------------------------------------------------------------------------

# Backend API host (production fallback lives in src/utils/config.ts)
EXPO_PUBLIC_BACKEND_URL=https://api.getrouted.xyz

# Toggle the native map implementation ("true" | "false")
EXPO_PUBLIC_USE_NATIVE_MAP=true

# Disable dev-only behaviour in production builds
EXPO_PUBLIC_DEV_MODE=false

# Optional: override the privacy policy URL
EXPO_PUBLIC_PRIVACY_POLICY_URL=

# --- Supabase --------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# --- Google OAuth Client IDs ----------------------------------------------
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<project-id>.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<project-id>.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<project-id>.apps.googleusercontent.com
